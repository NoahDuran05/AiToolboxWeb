@page "/"
@rendermode InteractiveServer

@using Aloha.Generator

@inject ImageServiceLibrary Flux
@inject TextServiceLibrary DeepSeek

<h1>AI Toolbox</h1>

<button @onclick="OpenImage">
    Generate Image
</button>

<button @onclick="OpenText">
    Generate Text
</button>

<br />
<br />

@if (!string.IsNullOrWhiteSpace(errorMessage))
{
    <div class="error-message">
        <strong>Error:</strong> @errorMessage
    </div>
}

<div class="tool-container">

    @if (showImage)
    {
        <div class="toolbox">
            <h3>Image Generator</h3>

            <label>Model Name</label>
            <br />

            <select @bind="imageModelName">
                <option value="FLUX.2-pro">FLUX.2-pro</option>
                <option value="gpt-image-2">gpt-image-2</option>
            </select>

            <br />
            <br />

            <label>Prompt</label>
            <br />

            <textarea class="prompt-box"
                      @bind="imagePrompt"></textarea>

            <br />

            <button @onclick="GenerateImage"
                    disabled="@isGeneratingImage">
                @(isGeneratingImage ? "Generating..." : "Generate")
            </button>
        </div>
    }

    @if (showText)
    {
        <div class="toolbox">
            <h3>Text Generator</h3>

            <label>Model Name</label>
            <br />

            <select @bind="textModelName">
                <option value="grok-4-20-reasoning">
                    grok-4-20-reasoning
                </option>

                <option value="DeepSeek-V4-Pro">
                    DeepSeek-V4-Pro
                </option>

                <option value="gpt-5.4">
                    gpt-5.4
                </option>
            </select>

            <br />
            <br />

            <label>Temperature</label>
            <br />

            <input type="number"
                   step="0.1"
                   min="0"
                   max="1"
                   @bind="temperature" />

            <br />
            <br />

            <label>System Prompt</label>
            <br />

            <textarea class="prompt-box"
                      @bind="systemPrompt"></textarea>

            <br />
            <br />

            <label>User Prompt</label>
            <br />

            <textarea class="prompt-box"
                      @bind="textPrompt"></textarea>

            <br />

            <button @onclick="GenerateText"
                    disabled="@isGeneratingText">
                @(isGeneratingText ? "Generating..." : "Generate")
            </button>
        </div>
    }

</div>

@if (showImageModal && !string.IsNullOrWhiteSpace(imageDataUrl))
{
    <div class="modal-overlay">
        <div class="modal-window">
            <img src="@imageDataUrl"
                 alt="Generated image"
                 class="generated-image" />

            <br />
            <br />

            <button @onclick="CloseImageModal">
                Close
            </button>
        </div>
    </div>
}

@if (showTextModal)
{
    <div class="modal-overlay">
        <div class="modal-window">
            <div class="text-response">
                @textResponse
            </div>

            <br />
            <br />

            <button @onclick="CloseTextModal">
                Close
            </button>
        </div>
    </div>
}

<style>
    .tool-container {
        display: flex;
        gap: 30px;
        align-items: flex-start;
        flex-wrap: wrap;
    }

    .toolbox {
        flex: 1;
        min-width: 300px;
        max-width: 700px;
    }

    .prompt-box {
        width: 100%;
        height: 130px;
    }

    .modal-overlay {
        position: fixed;
        inset: 0;
        z-index: 1000;
        background-color: rgba(0, 0, 0, 0.6);
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 20px;
    }

    .modal-window {
        background-color: white;
        padding: 25px;
        width: 100%;
        max-width: 800px;
        max-height: 90vh;
        overflow: auto;
    }

    .generated-image {
        display: block;
        max-width: 100%;
        height: auto;
    }

    .text-response {
        max-width: 700px;
        white-space: pre-wrap;
        overflow-wrap: anywhere;
    }

    .error-message {
        margin: 15px 0;
        padding: 12px;
        border: 1px solid #b42318;
        color: #b42318;
    }
</style>

@code {
    private bool showImage;
    private bool showText;
    private bool showImageModal;
    private bool showTextModal;
    private bool isGeneratingImage;
    private bool isGeneratingText;

    private string imagePrompt = "";
    private string imageModelName = "FLUX.2-pro";

    private string textPrompt = "";
    private string systemPrompt =
        "You are a helpful AI assistant.";

    private string textModelName =
        "DeepSeek-V4-Pro";

    private float temperature = 0.7f;

    private string? imageDataUrl;
    private string? textResponse;
    private string? errorMessage;

    private void OpenImage()
    {
        showImage = true;
        errorMessage = null;
    }

    private void OpenText()
    {
        showText = true;
        errorMessage = null;
    }

    private async Task GenerateImage()
    {
        if (string.IsNullOrWhiteSpace(imagePrompt))
        {
            errorMessage = "Enter an image prompt.";
            return;
        }

        try
        {
            isGeneratingImage = true;
            errorMessage = null;

            IEnumerable<byte> result =
                await Flux.GenerateImageAsync(
                    imagePrompt,
                    imageModelName);

            byte[] imageBytes = result.ToArray();

            if (imageBytes.Length == 0)
            {
                throw new InvalidOperationException(
                    "The image service returned no image data.");
            }

            imageDataUrl =
                $"data:image/png;base64,{Convert.ToBase64String(imageBytes)}";

            showImageModal = true;
        }
        catch (Exception exception)
        {
            errorMessage = exception.Message;
        }
        finally
        {
            isGeneratingImage = false;
        }
    }

    private async Task GenerateText()
    {
        if (string.IsNullOrWhiteSpace(textPrompt))
        {
            errorMessage = "Enter a text prompt.";
            return;
        }

        try
        {
            isGeneratingText = true;
            errorMessage = null;

            textResponse =
                await DeepSeek.GenerateTextAsync(
                    textPrompt,
                    systemPrompt,
                    textModelName,
                    temperature);

            showTextModal = true;
        }
        catch (Exception exception)
        {
            errorMessage = exception.Message;
        }
        finally
        {
            isGeneratingText = false;
        }
    }

    private void CloseImageModal()
    {
        showImageModal = false;
    }

    private void CloseTextModal()
    {
        showTextModal = false;
    }
}